{
  "name": "agent-ui",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build",
    "electron:package": "cd agent-backend && npm run build && cd .. && npm run electron:build",
    "electron:package:win": "cd agent-backend ; npm run build ; cd .. ; npm run electron:build",
    "electron:dist": "cd agent-backend ; npm run build ; cd .. ; npm run electron:build ; cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win"
  },
  "build": {
    "appId": "com.agent-ui.app",
    "productName": "Self-Diy-Agent",
    "asar": {
      "smartUnpack": true
    },
    "npmRebuild": false,
    "directories": {
      "output": "releases"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "agent-backend/dist",
        "to": "agent-backend/dist"
      },
      {
        "from": "agent-backend/package.json",
        "to": "agent-backend/package.json"
      },
      {
        "from": "agent-backend/node_modules",
        "to": "agent-backend/node_modules",
        "filter": [
          "**/*",
          "!**/docs",
          "!**/test",
          "!**/tests",
          "!**/*.md",
          "!**/*.map"
        ]
      },
      {
        "from": "agent-backend/.env",
        "to": "agent-backend/.env"
      },
      {
        "from": "agent-backend/specs",
        "to": "agent-backend/specs"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@json-render/core": "^0.19.0",
    "@json-render/react": "^0.19.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.1",
    "wait-on": "^8.0.4"
  }
}
