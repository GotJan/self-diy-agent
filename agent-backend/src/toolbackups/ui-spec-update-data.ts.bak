/**
 * update_ui_data —— 批量更新 UI spec 组件中元素的 props 数据
 *
 * 支持两种模式：
 *   1. 批量: updates = [{ elementId, props }, ...]
 *   2. 单元素兼容: elementId + props（自动转为单元素数组）
 */

import { tool } from '@langchain/core/tools';
import { z } from 'zod';
import fs from 'fs';
import path from 'path';
import { SPECS_DIR, sanitizeName, extractDataSchema } from './utils.js';

export const updateUiDataTool = tool(
  ({ name, updates, elementId, props }) => {
    const safeName = sanitizeName(name);
    const filePath = path.join(SPECS_DIR, `${safeName}.json`);

    if (!fs.existsSync(filePath)) {
      return { success: false, error: `UI spec '${safeName}' 不存在。` };
    }

    let spec: any;
    try {
      spec = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    } catch {
      return { success: false, error: `无法解析 spec 文件 '${safeName}.json'` };
    }

    // 统一到 data 层
    const elements = spec.data?.elements || spec.elements || {};

    // 构建批量更新列表：优先用 updates 数组，兼容单 elementId + props
    let batch: { elementId: string; props: Record<string, any> }[];
    if (updates && Array.isArray(updates) && updates.length > 0) {
      batch = updates as { elementId: string; props: Record<string, any> }[];
    } else if (elementId && props) {
      batch = [{ elementId, props }];
    } else {
      return { success: false, error: '请提供 updates 数组（推荐）或 elementId+props（兼容），不能都为空。' };
    }

    // 预先校验所有 elementId
    const errors: string[] = [];
    for (const item of batch) {
      if (!elements[item.elementId]) {
        errors.push(`'${item.elementId}' 不存在。可用: ${Object.keys(elements).join(', ') || '(none)'}`);
      }
    }
    if (errors.length > 0) {
      return { success: false, error: `以下元素不存在:\n${errors.map((e) => `  - ${e}`).join('\n')}` };
    }

    // 批量合并 props
    const updatedIds: string[] = [];
    for (const item of batch) {
      if (item.props && typeof item.props === 'object') {
        elements[item.elementId].props = {
          ...elements[item.elementId].props,
          ...item.props,
        };
      }
      updatedIds.push(item.elementId);
    }

    // 写回 data 层
    if (spec.data) {
      spec.data.elements = elements;
    } else {
      spec.elements = elements;
    }

    spec._dataUpdated = new Date().toISOString();
    fs.writeFileSync(filePath, JSON.stringify(spec, null, 2), 'utf-8');

    return {
      success: true,
      name: safeName,
      updatedCount: updatedIds.length,
      updatedIds,
      updatedProps: Object.fromEntries(
        updatedIds.map((id) => [id, elements[id].props])
      ),
      dataSchema: extractDataSchema(elements),
      message: `成功更新 spec '${safeName}' 中 ${updatedIds.length} 个元素: ${updatedIds.join(', ')}。`,
    };
  },
  {
    name: 'update_ui_data',
    description:
      '批量更新 UI spec 组件中元素的 props 数据。传入 updates 数组，一次调用更新多个元素。\n' +
      '也兼容单元素模式（elementId + props）。\n' +
      '⚠️ 调用前必须先调 get_ui_data 查看组件的 dataSchema，确认每个 elementId 和可用的 props 键名后再更新。',
    schema: z.object({
      name: z.string().describe('UI spec 名称（不含 .json 后缀）'),
      updates: z.array(z.object({
        elementId: z.string().describe('要更新的元素 ID（来自 dataSchema 的 key），如 "heading-1"'),
        props: z.record(z.string(), z.any()).describe('要更新/合并的 props 键值对，如 { "text": "hello" }'),
      })).optional().describe('批量更新列表。推荐使用，一次调用更新多个元素。'),
      elementId: z.string().optional().describe('（兼容单元素）要更新的元素 ID'),
      props: z.record(z.string(), z.any()).optional().describe('（兼容单元素）要更新/合并的 props 键值对'),
    }),
  }
);
